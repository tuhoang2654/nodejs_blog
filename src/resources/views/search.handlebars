<div class="mt-4">
    <form method="POST" action="">
        <div class="form-group">
            <label for="search-input">Enter Keyword</label>
            <input type="text" class="form-control" name="q" id="search-input" placeholder="Enter keyword">
        </div>

        <div class="form-group"></div>
        <label for="gender-input">Select gender</label>
        <select class="form-control" name="gender" id="search-input"> 
            <option value="">Select gender</option>
            <option value="male">Male</option>
            <option value="female">Female</option>
        </select>
</div>

<button type="submit" class="btn btn-primary mt-4">Search</button>
</form>
</div>